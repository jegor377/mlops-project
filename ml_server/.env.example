ENV=development
HOSTNAME=http://localhost:5173
FRONTEND_HOSTNAME=http://localhost:5173
DB_URI=postgresql://postgres:postgres@127.0.0.1:8081/dev_db
REDIS_URI=redis://127.0.0.1:6379/0
LOAD_MODEL=false
OAUTH_STATE_SESSION_SECRET_KEY=dummy-secret-key  # put it to /run/secrets/oauth_state_session_secret_key in production
SMTP__FROM_EMAIL_ADDRESS=no-reply@example.com
GOOGLE_OAUTH2_CREDS__CLIENT_ID=dummy-client-id
GOOGLE_OAUTH2_CREDS__CLIENT_SECRET=dummy-client-secret  # put it to /run/secrets/google_oauth2_creds__client_secret in production
GITHUB_OAUTH2_CREDS__CLIENT_ID=dummy-client-id
GITHUB_OAUTH2_CREDS__CLIENT_SECRET=dummy-client-secret  # put it to /run/secrets/github_oauth2_creds__client_secret in production
OAUTH_STATE_SESSION_SECRET_KEY=dummy-secret-key  # put it to /run/secrets/oauth_state_session_secret_key in production